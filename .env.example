# SD_WEBUI_URL: Free local AI — Stable Diffusion WebUI / Forge API (default: http://localhost:7860)
# Install Forge, add --api to webui-user.bat, start WebUI, then generate with zero API cost.
SD_WEBUI_URL="http://localhost:7860"

# OLLAMA_BASE_URL: Optional — Ollama image models work on macOS/Linux only (not Windows).
OLLAMA_BASE_URL="http://localhost:11434"

# GEMINI_API_KEY: Optional paid cloud fallback only — not required for local generation.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
